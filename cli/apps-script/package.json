{
  "name": "@mcpx-io/apps-script",
  "version": "2.0.4",
  "type": "commonjs",
  "description": "MCP local para Google Apps Script — listar, ler, editar scripts, criar versões e deployments",
  "bin": {
    "mcpx-apps-script": "dist/server.js"
  },
  "files": ["dist"],
  "publishConfig": {
