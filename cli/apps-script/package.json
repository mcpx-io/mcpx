  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^128.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
